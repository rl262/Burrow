# /etc/burrow/dashboard.env -- rendered by the Burrow installer from
# /etc/burrow/burrow.conf. Read by burrow-dashboard.service (EnvironmentFile).
# systemd EnvironmentFile syntax: KEY=VALUE, one per line, no shell quoting.
# Mode 0640 root:burrow -- contains the PowerDNS API key, session secret, and
# admin password. Do not commit a filled-in copy; regenerate on install.

# --- PowerDNS HTTP API (authoritative, loopback only) ----------------------
DNSMGR_PDNS_URL=${PDNS_API_URL}
DNSMGR_PDNS_API_KEY=${PDNS_API_KEY}
DNSMGR_PDNS_SERVER_ID=localhost
DNSMGR_FORWARD_ZONE=${LOCAL_DOMAIN}

# --- Unbound control (front-door recursive resolver on :53) -----------------
DNSMGR_UNBOUND_ENABLED=true
DNSMGR_UNBOUND_CONTROL=${UNBOUND_CONTROL}
DNSMGR_UNBOUND_CHECKCONF=${UNBOUND_CHECKCONF}
# App-owned include, rewritten atomically by the GUI then reloaded into Unbound.
# MUST live where the unbound daemon can read it (AppArmor allows /var/lib/unbound/**).
DNSMGR_UNBOUND_OVERRIDES_FILE=${UNBOUND_OVERRIDES_FILE}
DNSMGR_UNBOUND_REFRESH_SCRIPT=${BLOCKLIST_REFRESH_SCRIPT}
DNSMGR_UNBOUND_USE_SUDO=true

# --- Blocklists (Pi-hole-style adlists) -------------------------------------
DNSMGR_BLOCKLIST_ENABLED=true
DNSMGR_BLOCKLIST_DIR=${BLOCKLIST_DIR}
DNSMGR_BLOCKLIST_SOURCES_FILE=${BLOCKLIST_DIR}/sources.txt
DNSMGR_BLOCKLIST_GUI_FILE=${BLOCKLIST_DIR}/sources.d/gui.txt
DNSMGR_BLOCKLIST_STATUS_FILE=${BLOCKLIST_DIR}/status
DNSMGR_BLOCKLIST_REFRESH_SERVICE=burrow-blocklist-refresh.service
DNSMGR_SYSTEMCTL=/usr/bin/systemctl

# --- Blocked-request monitor (live 'activity' feed) -------------------------
# Tails the Unbound journal for always_nxdomain block events. The burrow user
# reads the journal via systemd-journal group membership (no sudo).
DNSMGR_BLOCKED_ENABLED=true
DNSMGR_BLOCKED_JOURNAL_UNIT=unbound.service
DNSMGR_JOURNALCTL=/usr/bin/journalctl

# --- Authentication ---------------------------------------------------------
# password mode: shared admin password + signed session cookie.
DNSMGR_AUTH_MODE=password
# DNSMGR_APP_PASSWORD is appended by the installer (single-quote-escaped) so that
# shell/systemd-significant characters in the password survive verbatim.
# Stable secret so sessions survive restarts: openssl rand -hex 32 (installer-generated).
DNSMGR_SESSION_SECRET=${DASHBOARD_SESSION_SECRET}

# --- Cosmetic ---------------------------------------------------------------
DNSMGR_SITE_TITLE=${LOCAL_DOMAIN}
